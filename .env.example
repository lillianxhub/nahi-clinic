# Environment variables for Nahi Clinic
# Copy this file to .env.development or .env.production and fill in the values

# Database URL
# For development (Local PostgreSQL): postgresql://postgres:postgres@localhost:5432/nahi_clinic?schema=public
# For production: Connection string from your database provider
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nahi_clinic
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?schema=public"

# Next Auth
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Use http://localhost:3000 for development
NEXTAUTH_URL="http://localhost:3000"

# App Config
# Use http://localhost:3000/api for development
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NODE_ENV="development"
TZ="Asia/Bangkok"